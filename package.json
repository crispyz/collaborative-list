{
  "name": "collaborative-list",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run api:dev\" \"npm run web:dev\"",
    "api:dev": "npm run -w @collab/api dev",
    "api:build": "npm run -w @collab/api build",
    "api:start": "npm run -w @collab/api start",
    "web:dev": "npm run -w @collab/web dev",
    "web:build": "npm run -w @collab/web build",
    "web:start": "npm run -w @collab/web start",
    "typecheck": "npm run --workspaces --if-present typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:api": "bash apps/api/scripts/smoke-test.sh",
    "test:ws": "tsx apps/api/scripts/ws-smoke.ts",
    "test": "npm run test:api && npm run test:ws",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "npm run -w @collab/db generate",
    "db:migrate": "npm run -w @collab/db migrate",
    "db:studio": "npm run -w @collab/db studio"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
